[submodule "dotbot"]
	path = modules/dotbot
	url = https://github.com/anishathalye/dotbot
	ignore = dirty
[submodule "dotbot-ifplatform"]
	path = modules/dotbot-ifplatform
	url = https://github.com/ssbanerje/dotbot-ifplatform.git
[submodule "dotbot-yay"]
	path = modules/dotbot-yay
	url = https://github.com/bjornsnoen/dotbot-yay.git
[submodule "dotbot-apt"]
	path = modules/dotbot-apt
	url = https://github.com/bryant1410/dotbot-apt
[submodule "dotbot-git"]
	path = modules/dotbot-git
	url = https://github.com/DrDynamic/dotbot-git.git
