    "height": 20, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
    "modules-left": ["wlr/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "temperature", "backlight", "battery", "tray"],
