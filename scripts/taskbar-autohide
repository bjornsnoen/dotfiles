#!/usr/bin/env sh
set -eu

if ! command -v powershell.exe >/dev/null 2>&1; then
    echo "taskbar-autohide: powershell.exe not found" >&2
    exit 127
fi

mode=${1:-toggle}

case "$mode" in
    enable|disable|toggle|status)
        ;;
    *)
        echo "usage: taskbar-autohide [enable|disable|toggle|status]" >&2
        exit 2
        ;;
esac

powershell.exe -NoLogo -NoProfile -NonInteractive -Command '
$ErrorActionPreference = "Stop"
$mode = "'"$mode"'"
Add-Type @"
using System;
using System.Runtime.InteropServices;

public static class TaskbarApi {
    [StructLayout(LayoutKind.Sequential)]
    public struct RECT {
        public int Left;
        public int Top;
        public int Right;
        public int Bottom;
    }

    [StructLayout(LayoutKind.Sequential)]
    public struct APPBARDATA {
        public int cbSize;
        public IntPtr hWnd;
        public uint uCallbackMessage;
        public uint uEdge;
        public RECT rc;
        public IntPtr lParam;
    }

    [DllImport("user32.dll", CharSet = CharSet.Auto)]
    public static extern IntPtr FindWindow(string lpClassName, string lpWindowName);

    [DllImport("shell32.dll")]
    public static extern UIntPtr SHAppBarMessage(uint dwMessage, ref APPBARDATA pData);
}
"@

$ABM_GETSTATE = 0x00000004
$ABM_SETSTATE = 0x0000000A
$ABS_AUTOHIDE = 0x00000001

$appBar = New-Object TaskbarApi+APPBARDATA
$appBar.cbSize = [System.Runtime.InteropServices.Marshal]::SizeOf($appBar)
$appBar.hWnd = [TaskbarApi]::FindWindow("Shell_TrayWnd", $null)

if ($appBar.hWnd -eq [IntPtr]::Zero) {
    throw "Could not find the Windows taskbar"
}

$state = [uint32][TaskbarApi]::SHAppBarMessage($ABM_GETSTATE, [ref]$appBar).ToUInt32()
$isEnabled = ($state -band $ABS_AUTOHIDE) -ne 0

switch ($mode) {
    "enable" { $target = $true }
    "disable" { $target = $false }
    "toggle" { $target = -not $isEnabled }
    "status" {
        if ($isEnabled) {
            Write-Output "enabled"
        } else {
            Write-Output "disabled"
        }
        exit 0
    }
}

if ($target) {
    $label = "enabled"
    $newState = $state -bor $ABS_AUTOHIDE
} else {
    $label = "disabled"
    $newState = $state -band (-bnot $ABS_AUTOHIDE)
}

$appBar.lParam = [IntPtr]$newState
[TaskbarApi]::SHAppBarMessage($ABM_SETSTATE, [ref]$appBar) | Out-Null
Write-Output $label
' | tr -d '\r'
